# ============================================
# POTRZEBNY.AI - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in your values
# RELEASE: 2026-01-07 | VERSION: 1.0.0
# ============================================

# =====================
# SUPABASE (REQUIRED)
# Get from: https://supabase.com/dashboard
# =====================
NEXT_PUBLIC_SUPABASE_URL=https://klboejvukyywtpiopevn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# =====================
# STRIPE (REQUIRED FOR PAYMENTS)
# Get from: https://dashboard.stripe.com/apikeys
# Must start with: pk_live_ / sk_live_ / whsec_
# =====================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =====================
# AUTHENTICATION
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# =====================
NEXTAUTH_SECRET=your_32_char_minimum_secret_here
NEXTAUTH_URL=https://potrzebny.ai

# =====================
# SENTRY (ERROR TRACKING)
# Get from: https://sentry.io/settings/
# =====================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=potrzebny-ai
SENTRY_PROJECT=production

# =====================
# AI APIs
# Anthropic: https://console.anthropic.com/
# Perplexity: https://www.perplexity.ai/settings/api
# Must start with: sk-ant- / pplx-
# =====================
ANTHROPIC_API_KEY=sk-ant-xxx
PERPLEXITY_API_KEY=pplx-xxx

# =====================
# RESEARCH APIs
# =====================
NCBI_API_KEY=your_ncbi_key
SCOPUS_API_KEY=your_scopus_key
EXA_API_KEY=your_exa_key
BRAVE_SEARCH_API_KEY=BSAxxx

# =====================
# GOOGLE CLOUD
# Get from: https://console.cloud.google.com/apis/credentials
# Must start with: AIza
# =====================
GOOGLE_CLOUD_API_KEY=AIzaxxx
GOOGLE_CLOUD_PROJECT_ID=potrzebny-ai-prod

# =====================
# APP CONFIG
# =====================
NEXT_PUBLIC_APP_URL=https://potrzebny.ai
NODE_ENV=production

# =====================
# VERCEL (FOR CI/CD)
# Get from: https://vercel.com/account/tokens
# =====================
VERCEL_TOKEN=your_vercel_token
