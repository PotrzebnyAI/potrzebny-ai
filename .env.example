# Google Service Account (Domain-Wide Delegation)
# ==================================================
# Service Account: gmail-full-access-service-acco@potrzebny-ai-prod.iam.gserviceaccount.com
# Client ID: 116898976924675896210
#
# AVAILABLE SCOPES:
# - Gmail: full access, settings, compose, send
# - Drive: full access, files, metadata
# - Calendar: events, readonly
# - Sheets: full access
# - Docs: full access
# - Admin: directory, users, groups
#
# HOW TO GET THE KEY:
# 1. Open Cloud Shell: https://console.cloud.google.com/?cloudshell=true
# 2. Run:
#    gcloud iam service-accounts keys create ~/gmail-drive-key.json \
#      --iam-account=gmail-full-access-service-acco@potrzebny-ai-prod.iam.gserviceaccount.com
#    cat ~/gmail-drive-key.json
# 3. Copy the entire JSON output and paste below (single line, no newlines)
#
# IMPORTANT: Store the JSON as a single line string!
# Example: {"type":"service_account","project_id":"potrzebny-ai-prod",...}
GOOGLE_SERVICE_ACCOUNT_KEY=

# AI APIs
ANTHROPIC_API_KEY=sk-ant-xxx
PERPLEXITY_API_KEY=pplx-xxx
EXA_API_KEY=xxx

# Research APIs
